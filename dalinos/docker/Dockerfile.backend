# Dockerfile for DalinOS Backend

FROM rust:1.70-slim AS builder

WORKDIR /app
COPY . .
RUN cargo install --path .

FROM debian:bookworm-slim
RUN apt-get update && apt-get install -y ca-certificates && rm -rf /var/lib/apt/lists/*
COPY --from=builder /app/target/release/dalinos-backend /usr/local/bin/dalinos-backend

EXPOSE 3000
CMD ["dalinos-backend"]
